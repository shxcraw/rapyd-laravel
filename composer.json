{
    "name": "shxcraw/rapyd",
    "description": "crud widgets for laravel, to make an admin in few lines of code",
    "homepage": "https://github.com/shxcraw/rapyd-laravel",
    "keywords": ["laravel", "crud", "rapyd", "administrator", "admin", "backend", "datatable", "form"],
    "authors": [
        {
            "name": "zofe",
            "email": "felice.ostuni@gmail.com"
        }
    ],
    "repositories": [
        {
            "type": "vcs",
            "url": "https://github.com/shxcraw/burp"
        }
    ],
    "require": {
        "php": ">=7.1",
        "laravel/framework": "^7.0",
        "intervention/image": "2.4.2",
        "shxcraw/burp": "^7.0"
    },
    "suggest": {
        "baum/baum": "Allows to use the DataTree widget"
    },
    "autoload": {
        "classmap": [
            "migrations"
        ],
        "psr-4": {
            "Zofe\\Rapyd\\": "src/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Zofe\\Rapyd\\RapydServiceProvider"
            ]
        }
    },
    "require-dev": {
        "laravel/framework": "^7.0",
        "orchestra/testbench": "3.6.*",
        "phpunit/phpunit": "7.*",
        "php-coveralls/php-coveralls": "^1.0"
    }
}
